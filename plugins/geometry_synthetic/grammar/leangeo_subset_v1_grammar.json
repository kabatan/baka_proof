{
  "schema_version": "1.0.0",
  "grammar_id": "LeanGeoSubsetV1TheoremGrammar:1.0.0",
  "target_library": "LeanGeoSubsetV1:1.0.0",
  "object_declarations": [
    "point",
    "line",
    "circle",
    "line_through_two_distinct_points",
    "circle_with_center_through_point"
  ],
  "allowed_hypothesis_forms": [
    "distinct",
    "collinear",
    "parallel",
    "perpendicular",
    "midpoint",
    "concyclic",
    "equal_length",
    "equal_angle_supported_pattern"
  ],
  "allowed_target_forms": [
    "collinear",
    "parallel",
    "perpendicular",
    "concyclic",
    "equal_length",
    "equal_angle_supported_pattern"
  ],
  "rejected_hypothesis_forms": [
    "arbitrary_mathlib_expression",
    "unsupported_local_notation",
    "unsupported_quantifier_alternation",
    "unsupported_orientation_semantics",
    "unsupported_diagram_case_split"
  ],
  "rejected_target_forms": [
    "arbitrary_mathlib_expression",
    "unsupported_local_notation",
    "unsupported_quantifier_alternation",
    "unsupported_orientation_semantics",
    "unsupported_diagram_case_split"
  ],
  "predicate_mappings": {
    "collinear": {"side_conditions": ["points_declared"], "unsupported_variants": ["set_collinearity"]},
    "parallel": {"side_conditions": ["lines_declared", "nondegenerate_lines"], "unsupported_variants": ["directed_parallel_orientation"]},
    "perpendicular": {"side_conditions": ["lines_declared", "nondegenerate_lines"], "unsupported_variants": ["angle_encoded_perpendicular"]},
    "midpoint": {"side_conditions": ["points_declared", "endpoints_distinct"], "unsupported_variants": ["segment_object_midpoint"]},
    "concyclic": {"side_conditions": ["points_declared"], "unsupported_variants": ["oriented_circle_arc"]},
    "equal_length": {"side_conditions": ["segments_declared"], "unsupported_variants": ["norm_expression"]},
    "equal_angle_supported_pattern": {"side_conditions": ["registered_angle_pattern"], "unsupported_variants": ["arbitrary_oriented_angle"]}
  },
  "construction_mappings": {
    "line_through_two_distinct_points": {"side_conditions": ["points_distinct"]},
    "intersection_of_two_nonparallel_lines": {"side_conditions": ["lines_nonparallel"]},
    "foot_of_perpendicular": {"side_conditions": ["point_declared", "line_declared"]},
    "midpoint": {"side_conditions": ["endpoints_distinct"]},
    "circle_with_center_through_point": {"side_conditions": ["center_point_distinct"]}
  },
  "relation_mappings": {
    "exact": {"goal_level_allowed": true},
    "sufficient": {
      "goal_level_allowed": true,
      "requires_direction_check": true,
      "allowed_directions": ["forward", "reverse"]
    },
    "related": {"goal_level_allowed": false},
    "none": {"goal_level_allowed": false}
  },
  "safe_reject_policy": "reject_unsupported_or_ambiguous_forms_before_proof_use"
}
