{
  "$id": "resources.public_contracts.v1",
  "type": "object",
  "required": ["schema_version", "contract_schemas"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0.0"]},
    "contract_schemas": {
      "type": "object",
      "required": ["LocalResourceProfile", "ResourceBudgetProfile", "ResourceUsageReport"],
      "properties": {
        "LocalResourceProfile": {
          "required_fields": [
            "schema_version",
            "profile_id",
            "created_at",
            "os",
            "cpu_physical_cores",
            "cpu_logical_cores",
            "total_ram_mb",
            "available_ram_mb_at_probe",
            "gpu_devices",
            "disk_free_mb",
            "lean_build_parallelism_default",
            "provider_engine_availability"
          ],
          "provenance_fields": ["profile_id"],
          "status_fields": ["provider_engine_availability"],
          "proof_use_fields": []
        },
        "ResourceBudgetProfile": {
          "required_fields": ["schema_version", "budget_id", "budget_class", "timeout_seconds", "semaphore_requests"],
          "provenance_fields": [],
          "status_fields": ["budget_class"],
          "proof_use_fields": [],
          "allowed_values": {"budget_class": ["tiny", "small", "medium", "heavy", "extreme"]}
        },
        "ResourceUsageReport": {
          "required_fields": ["schema_version", "report_id", "run_id", "role", "admission_status", "started_at", "ended_at", "exit_status"],
          "provenance_fields": ["run_id"],
          "status_fields": ["role", "admission_status", "exit_status"],
          "proof_use_fields": [],
          "allowed_values": {
            "role": ["lean", "proof_worker", "symbolic_closure", "construction_proposer", "heavy_search"],
            "admission_status": ["admitted", "rejected", "timeout", "killed"],
            "exit_status": ["completed", "failed", "timeout", "killed", "not_started"]
          }
        }
      }
    }
  }
}
