{
  "$id": "model_api.public_contracts.v1",
  "type": "object",
  "required": ["schema_version", "contract_schemas"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0.0"]},
    "contract_schemas": {
      "type": "object",
      "required": [
        "ModelProviderSetManifest",
        "ModelSlot",
        "ModelInvocationRequest",
        "ModelInvocationRecord",
        "ResearchControllerPlugin",
        "ProofWorkerPlugin",
        "ResearchStatePack",
        "WorkerStatePack",
        "ActionPlan",
        "WorkOrder",
        "WorkerResult",
        "ControllerStrategyLog"
      ],
      "properties": {
        "ModelProviderSetManifest": {
          "required_fields": ["schema_version", "provider_set_id", "version", "slots"],
          "provenance_fields": ["manifest_ref"],
          "status_fields": [],
          "proof_use_fields": []
        },
        "ModelSlot": {
          "required_fields": ["schema_version", "slot_id", "provider", "model_ref", "capabilities"],
          "provenance_fields": ["model_ref"],
          "status_fields": [],
          "proof_use_fields": []
        },
        "ModelInvocationRequest": {
          "required_fields": ["schema_version", "request_id", "slot_id", "task_kind", "input_artifact_refs", "resource_budget"],
          "provenance_fields": ["input_artifact_refs"],
          "status_fields": ["task_kind"],
          "proof_use_fields": []
        },
        "ModelInvocationRecord": {
          "required_fields": ["schema_version", "invocation_id", "request_id", "slot_id", "status", "provider_set_hash", "input_hash", "request_hash", "response_hash", "output_artifact_ref", "proof_use_status"],
          "provenance_fields": ["provider_set_hash", "input_hash", "request_hash", "response_hash", "output_artifact_ref", "redacted_transcript_artifact_ref", "usage_metadata"],
          "status_fields": ["status"],
          "proof_use_fields": ["proof_use_status"],
          "allowed_values": {"status": ["completed", "failed", "timeout", "resource_rejected"], "proof_use_status": ["not_allowed"]}
        },
        "ResearchControllerPlugin": {
          "required_fields": ["schema_version", "plugin_id", "declared_model_slots", "capabilities", "manifest_ref"],
          "provenance_fields": ["manifest_ref"],
          "status_fields": [],
          "proof_use_fields": []
        },
        "ProofWorkerPlugin": {
          "required_fields": ["schema_version", "plugin_id", "declared_model_slots", "proof_region_policy", "manifest_ref"],
          "provenance_fields": ["manifest_ref"],
          "status_fields": [],
          "proof_use_fields": []
        },
        "ResearchStatePack": {
          "required_fields": ["schema_version", "state_id", "proof_state_summary_ref", "selected_implementations_ref", "artifact_refs"],
          "provenance_fields": ["proof_state_summary_ref", "selected_implementations_ref", "artifact_refs"],
          "status_fields": [],
          "proof_use_fields": []
        },
        "WorkerStatePack": {
          "required_fields": ["schema_version", "state_id", "work_order_id", "proof_region_ref", "artifact_refs"],
          "provenance_fields": ["proof_region_ref", "artifact_refs"],
          "status_fields": [],
          "proof_use_fields": []
        },
        "ActionPlan": {
          "required_fields": ["schema_version", "plan_id", "task_kinds", "constraints", "escalation_policy", "artifact_refs", "proof_use_note"],
          "provenance_fields": ["artifact_refs"],
          "status_fields": ["task_kinds"],
          "proof_use_fields": ["proof_use_note"]
        },
        "WorkOrder": {
          "required_fields": ["schema_version", "work_order_id", "task_kind", "target_obligation_id", "constraints", "artifact_refs", "proof_use_note"],
          "provenance_fields": ["target_obligation_id", "artifact_refs"],
          "status_fields": ["task_kind"],
          "proof_use_fields": ["proof_use_note"]
        },
        "WorkerResult": {
          "required_fields": ["schema_version", "worker_result_id", "work_order_id", "status", "patch_candidate_ref", "final_verify_ref", "proof_use_note", "patch_applied", "generated_candidate_file_ref", "proof_region_diff_hash", "solver_dependency_refs"],
          "provenance_fields": ["work_order_id", "patch_candidate_ref", "final_verify_ref", "generated_candidate_file_ref", "proof_region_diff_hash", "solver_dependency_refs"],
          "status_fields": ["status", "patch_applied"],
          "proof_use_fields": ["proof_use_note"],
          "allowed_values": {"status": ["success_claimed", "patch_candidate", "patch_applied", "blocked", "failed"]}
        },
        "ControllerStrategyLog": {
          "required_fields": ["schema_version", "log_id", "run_id", "capability_flags", "strategy_counts", "status", "artifact_refs", "proof_use_note"],
          "provenance_fields": ["run_id", "artifact_refs"],
          "status_fields": ["status"],
          "proof_use_fields": ["proof_use_note"],
          "allowed_values": {"status": ["used_in_search", "diagnostic_only", "abandoned", "refuted_key_branch"]}
        }
      }
    }
  }
}
