{
  "$id": "base.dependency_resolution_report.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "created_at",
    "os",
    "python_version",
    "lean_version",
    "lake_version",
    "packages",
    "engines",
    "unresolved",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0.0"]},
    "report_id": {"type": "string"},
    "created_at": {"type": "string"},
    "os": {"type": "string"},
    "python_version": {"type": "string"},
    "lean_version": {"type": "string"},
    "lake_version": {"type": "string"},
    "packages": {"type": "array", "items": {"type": "object"}},
    "engines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "family",
          "code_install_status",
          "code_version_or_commit",
          "code_source",
          "expected_commit",
          "model_artifact_expected",
          "model_artifact_status",
          "model_checkpoint_hash",
          "model_inference_status",
          "public_discovery_evidence_ref",
          "claim_impact",
          "evidence_refs"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["symbolic_closure", "construction_proposer", "heavy_search"]
          },
          "family": {
            "type": "string",
            "enum": [
              "newclid_compatible",
              "genesisgeo_compatible",
              "tonggeometry_compatible"
            ]
          },
          "code_install_status": {
            "type": "string",
            "enum": ["installed", "vendored", "unavailable", "failed"]
          },
          "code_version_or_commit": {"type": "string"},
          "code_source": {
            "type": "string",
            "enum": ["pypi", "git", "local_vendor", "system_path", "release", "unknown"]
          },
          "expected_commit": {"type": ["string", "null"]},
          "model_artifact_expected": {"type": "boolean"},
          "model_artifact_status": {
            "type": "string",
            "enum": [
              "available",
              "admitted_unavailable_external_artifact",
              "unavailable",
              "failed",
              "not_applicable"
            ]
          },
          "model_checkpoint_hash": {"type": ["string", "null"]},
          "model_inference_status": {
            "type": "string",
            "enum": ["available", "unavailable", "failed", "not_applicable"]
          },
          "public_discovery_evidence_ref": {"type": ["string", "null"]},
          "claim_impact": {
            "type": "string",
            "enum": [
              "none",
              "blocks_core_experiment_ready",
              "blocks_model_backed_tonggeometry_claim",
              "blocks_provider_role"
            ]
          },
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "unresolved": {"type": "array", "items": {"type": "object"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}}
  }
}
