{
  "$id": "geometry.target_library_manifest.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target_library_id",
    "target_family",
    "source_dependency",
    "source_url",
    "version_or_commit",
    "expected_lean_version",
    "namespace_map_ref",
    "theorem_grammar_ref",
    "predicate_mapping_ref",
    "construction_mapping_ref",
    "relation_mapping_ref",
    "selected",
    "status",
    "blocker_reason"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0.0"]},
    "target_library_id": {"type": "string", "pattern": "LeanGeoSubsetV1:.+"},
    "target_family": {"type": "string", "enum": ["LeanGeoSubsetV1"]},
    "source_dependency": {"type": "string", "enum": ["LeanGeo-compatible"]},
    "source_url": {"type": "string"},
    "version_or_commit": {"type": "string"},
    "expected_lean_version": {"type": "string"},
    "namespace_map_ref": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
    "theorem_grammar_ref": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
    "predicate_mapping_ref": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
    "construction_mapping_ref": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
    "relation_mapping_ref": {"type": "string", "pattern": "sha256:[0-9a-f]{64}"},
    "selected": {"type": "boolean"},
    "status": {"type": "string", "enum": ["available", "blocked", "unavailable"]},
    "blocker_reason": {"type": "string"}
  }
}
