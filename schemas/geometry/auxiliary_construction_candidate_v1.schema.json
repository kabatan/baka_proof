{
  "$id": "geometry.auxiliary_construction_candidate_v1.v1",
  "type": "object",
  "required": [
    "schema_version",
    "candidate_id",
    "construction_kind",
    "source_provenance",
    "introduced_objects",
    "dependencies",
    "intended_use",
    "side_conditions",
    "proof_use_status"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0.0"]},
    "candidate_id": {"type": "string", "pattern": "^aux_construction_candidate:.*"},
    "construction_kind": {
      "type": "string",
      "enum": [
        "line_through_two_distinct_points",
        "intersection_of_two_nonparallel_lines",
        "foot_of_perpendicular",
        "midpoint",
        "circle_with_center_through_point"
      ]
    },
    "source_provenance": {"type": "string"},
    "introduced_objects": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "intended_use": {"type": "string"},
    "side_conditions": {"type": "array", "items": {"type": "string"}},
    "proof_use_status": {"type": "string", "enum": ["not_allowed", "lean_patch_candidate"]}
  },
  "additionalProperties": false
}
