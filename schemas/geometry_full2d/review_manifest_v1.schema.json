{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geometry_full2d.review_manifest_v1",
  "title": "ReviewManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_manifest_id",
    "reviewer_kind",
    "reviewer_id",
    "created_outside_codex_run",
    "reviewed_task_ids",
    "review_statement",
    "review_hash"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "review_manifest_id": {"type": "string", "pattern": "^ReviewManifestV1:sha256:[0-9a-f]{64}$"},
    "reviewer_kind": {"enum": ["user", "named_human_reviewer", "external_formal_source"]},
    "reviewer_id": {"type": "string", "minLength": 1},
    "created_outside_codex_run": {"type": "boolean"},
    "reviewed_task_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "source_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "review_statement": {"type": "string", "minLength": 1},
    "review_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
